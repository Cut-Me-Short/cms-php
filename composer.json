{
    "name": "cutmeshort/sdk",
    "description": "Official CutMeShort CMS PHP SDK. This SDK allows tracking of leads and sales, including deferred lead attribution.",
    "keywords": [
        "cutmeshort",
        "cms",
        "php",
        "sdk",
        "rest",
        "api",
        "tracking",
        "leads",
        "sales"
    ],
    "homepage": "https://www.cutmeshort.com",
    "license": "MIT",
    "type": "library",
    "support": {
        "issues": "https://github.com/Cut-Me-Short/cms-php/issues",
        "source": "https://github.com/Cut-Me-Short/cms-php"
    },
    "authors": [
        {
            "name": "CutMeShort",
            "homepage": "https://www.cutmeshort.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "guzzlehttp/guzzle": "^7.3",
        "guzzlehttp/psr7": "^1.7 || ^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0 || ^10.0",
        "friendsofphp/php-cs-fixer": "^3.5",
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": { "CutMeShort\\SDK\\" : "src/" }
    },
    "autoload-dev": {
        "psr-4": { "CutMeShort\\SDK\\Tests\\" : "test/" }
    }
}
